{
  "files.associations": {
    "*.md": "markdown"
  },
  "[markdown]": {
    "editor.wordWrap": "on"
  },
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "markup.heading.markdown heading.1.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.1.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.1.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.1.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#569cd6",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.heading.markdown heading.2.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.2.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.2.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.2.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#4ec9b0",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.heading.markdown heading.3.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.3.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.3.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.3.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#dcdcaa",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.heading.markdown heading.4.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.4.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.4.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.4.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#c586c0",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.heading.markdown heading.5.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.5.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.5.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.5.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#ce9178",
          "fontStyle": "bold"
        }
      },
      {
        "scope": [
          "markup.heading.markdown heading.6.markdown entity.name.section.markdown",
          "markup.heading.markdown heading.6.markdown punctuation.definition.heading.markdown",
          "text.html.markdown markup.heading.markdown heading.6.markdown entity.name.section.markdown",
          "text.html.markdown markup.heading.markdown heading.6.markdown punctuation.definition.heading.markdown"
        ],
        "settings": {
          "foreground": "#6a9955",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["markup.heading.setext.1.markdown", "markup.heading.setext"],
        "settings": {
          "foreground": "#569cd6",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "markup.heading.setext.2.markdown",
        "settings": {
          "foreground": "#4ec9b0",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "entity.name.section.markdown",
        "settings": {
          "foreground": "#569cd6",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "punctuation.definition.heading.markdown",
        "settings": {
          "foreground": "#569cd6",
          "fontStyle": "bold"
        }
      }
    ]
  }
}
